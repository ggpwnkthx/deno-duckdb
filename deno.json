{
  "name": "@ggpwnkthx/duckdb",
  "version": "1.1.15",
  "exports": {
    ".": "./src/mod.ts",
    "./functional": "./src/functional/mod.ts",
    "./objective": "./src/objective/mod.ts"
  },
  "lock": true,
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@ggpwnkthx/libduckdb": "jsr:@ggpwnkthx/libduckdb@1.0.15",
    "@ggpwnkthx/duckdb": "./src/mod.ts",
    "@ggpwnkthx/duckdb/functional": "./src/functional/mod.ts",
    "@ggpwnkthx/duckdb/objective": "./src/objective/mod.ts"
  },
  "tasks": {
    "test": "deno test -A ./tests/*",
    "coverage": "deno test -A --clean --coverage=coverage ./tests/* && deno coverage --output=coverage/coverage.txt --lcov",
    "coverage:check": "deno task coverage && deno run -A scripts/check_coverage.ts coverage/coverage.txt",
    "bench": "deno bench -A ./benchmarks/*",
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "lint": "deno lint",
    "check": "deno check ./src/*",
    "ci": "deno task fmt && deno task lint && deno task check && deno task coverage:check && deno task examples",
    "example:basic": "deno run -A ./examples/getting-started/basic.ts",
    "example:quickstart": "deno run -A ./examples/getting-started/quickstart.ts",
    "example:config:memory": "deno run -A ./examples/configuration/memory-and-threads.ts",
    "example:config:temp-dir": "deno run -A ./examples/configuration/temporary-directory.ts",
    "example:config:functional": "deno run -A ./examples/configuration/functional-api.ts",
    "example:config:file-based": "deno run -A ./examples/configuration/file-based.ts",
    "example:config:types": "deno run -A ./examples/configuration/types-overview.ts",
    "example:config": "deno task example:config:memory && deno task example:config:temp-dir && deno task example:config:functional && deno task example:config:file-based && deno task example:config:types",
    "example:window-functions": "deno run -A ./examples/analytics/window-functions.ts",
    "example:time-series": "deno run -A ./examples/analytics/time-series.ts",
    "example:parquet": "deno run -A ./examples/analytics/parquet.ts",
    "example:datatypes": "deno run -A ./examples/data-types/datatypes.ts",
    "example:azure": "deno run -A ./examples/cloud/azure.ts",
    "examples": "deno task example:basic && deno task example:quickstart && deno task example:config && deno task example:window-functions && deno task example:time-series && deno task example:parquet && deno task example:datatypes && deno task example:azure"
  },
  "compilerOptions": {
    "strict": true
  },
  "test": {
    "exclude": [
      "tests/utils.ts"
    ]
  },
  "fmt": {
    "lineWidth": 88,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "trailingCommas": "onlyMultiLine",
    "operatorPosition": "nextLine",
    "exclude": [
      "libduckdb",
      ".*"
    ]
  },
  "lint": {
    "exclude": [
      "libduckdb",
      ".opencode"
    ]
  },
  "exclude": [
    "libduckdb",
    ".opencode"
  ]
}
