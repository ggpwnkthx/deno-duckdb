{
  "name": "@ggpwnkthx/duckdb",
  "version": "1.1.13",
  "exports": {
    ".": "./src/mod.ts",
    "./functional": "./src/functional/mod.ts",
    "./objective": "./src/objective/mod.ts"
  },
  "lock": false,
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@ggpwnkthx/libduckdb": "jsr:@ggpwnkthx/libduckdb@1.0.14",
    "@ggpwnkthx/duckdb": "./src/mod.ts",
    "@ggpwnkthx/duckdb/functional": "./src/functional/mod.ts",
    "@ggpwnkthx/duckdb/objective": "./src/objective/mod.ts"
  },
  "tasks": {
    "test": "deno test -A ./tests/*",
    "bench": "deno bench -A ./benchmarks/*",
    "example:basic": "deno run -A ./examples/basic.ts",
    "example:analytics": "deno run -A ./examples/analytics.ts",
    "example:azure": "deno run -A ./examples/azure.ts",
    "example:datatypes": "deno run -A ./examples/datatypes.ts",
    "examples": "deno task example:basic && deno task example:analytics && deno task example:azure && deno task example:datatypes",
    "ci": "deno fmt && deno lint && deno check && deno task test"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 88,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "trailingCommas": "onlyMultiLine",
    "operatorPosition": "nextLine",
    "exclude": ["node_modules", ".git"]
  }
}
