{
  "name": "@ggpwnkthx/duckdb",
  "version": "1.1.13",
  "exports": {
    ".": "./src/mod.ts",
    "./functional": "./src/functional/mod.ts",
    "./objective": "./src/objective/mod.ts"
  },
  "lock": false,
  "imports": {
    "@std/assert": "jsr:@std/assert@1.0.19",
    "@ggpwnkthx/libduckdb": "jsr:@ggpwnkthx/libduckdb@1.0.15",
    "@ggpwnkthx/duckdb": "./src/mod.ts",
    "@ggpwnkthx/duckdb/functional": "./src/functional/mod.ts",
    "@ggpwnkthx/duckdb/objective": "./src/objective/mod.ts"
  },
  "tasks": {
    "test": "deno test -A ./tests/*",
    "bench": "deno bench -A ./benchmarks/*",
    "example:basic": "deno run -A ./examples/getting-started/basic.ts",
    "example:quickstart": "deno run -A ./examples/getting-started/quickstart.ts",
    "example:window-functions": "deno run -A ./examples/analytics/window-functions.ts",
    "example:time-series": "deno run -A ./examples/analytics/time-series.ts",
    "example:parquet": "deno run -A ./examples/analytics/parquet.ts",
    "example:datatypes": "deno run -A ./examples/data-types/datatypes.ts",
    "example:azure": "deno run -A ./examples/cloud/azure.ts",
    "examples": "deno task example:basic && deno task example:quickstart && deno task example:window-functions && deno task example:time-series && deno task example:parquet && deno task example:datatypes && deno task example:azure",
    "ci": "deno fmt && deno lint && deno check && deno task test"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 88,
    "indentWidth": 2,
    "useTabs": false,
    "semiColons": true,
    "singleQuote": false,
    "proseWrap": "preserve",
    "trailingCommas": "onlyMultiLine",
    "operatorPosition": "nextLine",
    "exclude": [
      "libduckdb",
      ".*"
    ]
  },
  "check": {
    "exclude": [
      "libduckdb",
      ".*"
    ]
  }
}
